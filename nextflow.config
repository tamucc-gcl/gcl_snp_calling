// nextflow.config

// Global default params
params {
    // Input/Output
    bams = "*.bam"
    reference = "reference.fasta"
    output_dir = "results"
    output_vcf = "combined_variants.vcf.gz" // Used as base name for all outputs
    
    // Processing parameters
    num_chunks = 10  // Number of chunks to split genome into

    // Genotyping method
    genotyper = "freebayes"  // "freebayes" or "angsd"
    
    // Configuration files
    freebayes_config = null
    bam_filter_config = null
    angsd_config = null

    // ANGSD specific
    sites_file = null

    // Help
    help = false
}

// Get detailed hash information
env {
  NXF_DEBUG = 0
}

process {
  executor = 'slurm'
  queue = 'normal'
  scratch = '/scratch'
  errorStrategy = 'retry'
  maxRetries = 2
  cache = 'lenient'

  // --- CREATE_CHUNKS ---
  // Trace data: 5 MB (small genomes) to 158 MB (large/fragmented genomes)
  // Reads .fai and runs a Python script; larger genomes with many contigs need more
  withName: CREATE_CHUNKS {
    cpus = 5
    time = '96h'
    memory = '2 GB'
    conda = 'bioconda::samtools=1.17'
  }

  // --- FILTER_BAMS ---
  // Trace data: 3 MB - 44.4 GB peak RSS
  // samtools sort/fixmate/markdup drive memory usage proportional to BAM size
  // Largest observed: 44.4 GB (RDA_5, 8-sample project with large BAMs)
  // Most samples in 90-sample project: < 10 GB
  // Dynamic: 24 GB -> 48 GB -> 72 GB on retries
  withName: FILTER_BAMS {
    cpus = 8
    time = '96h'
    memory = { 24.GB * task.attempt }
    conda = 'bioconda::samtools=1.17'
  }

  // --- FREEBAYES_CHUNK ---
  // Trace data: 152 MB - 1.9 GB peak RSS (8 samples, 50 chunks)
  //             312 MB - 503 MB peak RSS (90 samples, 25 chunks)
  // Much lower than expected - SNP-focused params keep memory in check
  // Dynamic: 24 GB -> 48 GB -> 72 GB on retries (generous headroom for
  //          pooled samples with higher ploidy or more complex regions)
  withName: FREEBAYES_CHUNK {
    cpus = 5
    time = '96h'
    memory = { 24.GB * task.attempt }
    conda = 'bioconda::freebayes=1.3.6 bioconda::samtools=1.17 bioconda::htslib=1.17'
  }

  // --- COMBINE_VCFS ---
  // Trace data: 19-20 MB peak RSS (bcftools concat streams data)
  withName: COMBINE_VCFS {
    cpus = 5
    time = '96h'
    memory = '2 GB'
    conda = 'bioconda::bcftools=1.17 bioconda::htslib=1.17'
  }

  // --- ANGSD_CHUNK ---
  // Trace data: 9.3 - 11.4 GB peak RSS (67 samples, 48 chunks)
  // ANGSD loads all BAMs into memory for GL calculation, so memory
  // scales primarily with n_samples × depth at each site
  // 16 GB covers observed max (11.4 GB) with headroom
  // Dynamic: 24 GB -> 48 GB -> 72 GB on retries (for larger sample sets)
  withName: ANGSD_CHUNK {
    cpus = 8
    time = '96h'
    memory = { 24.GB * task.attempt }
    cache = 'deep'
    conda = 'bioconda::angsd=0.940 bioconda::samtools=1.17 bioconda::htslib=1.17 bioconda::bcftools=1.17'
  }

  // --- COMBINE_ANGSD ---
  // Trace data: 366 MB peak RSS (streaming concat of chunk outputs)
  withName: COMBINE_ANGSD {
    cpus = 4
    time = '96h'
    memory = '2 GB'
    conda = 'bioconda::bcftools=1.17 bioconda::htslib=1.17 bioconda::tabix=1.11'
  }

  // --- PCANGSD ---
  // Trace data: 166 MB peak RSS (67 samples)
  // Covariance matrix is n_samples^2 × n_sites — light for moderate sample counts
  // Will grow substantially with hundreds of samples or millions of sites
  // Dynamic: 100 GB -> 200 GB -> 300 GB on retries
  withName: PCANGSD {
    cpus = 32
    time = '96h'
    memory = { 4.GB * task.attempt }
    conda = "$projectDir/envs/pcangsd.yaml"
  }

  // --- SUMMARIZE_VCFS ---
  // Trace data: 3 GB peak RSS (8 samples), 1 GB peak RSS (90 samples)
  // vcfR + adegenet load entire VCF into R memory
  // The 8-sample project had higher RSS because of larger per-sample data
  // Dynamic: 8 GB -> 16 GB -> 24 GB on retries
  withName: SUMMARIZE_VCFS {
    scratch = false
    cpus = 5
    time = '96h'
    memory = { 8.GB * task.attempt }
    conda = 'bioconda::bcftools=1.17 bioconda::htslib bioconda::vcftools conda-forge::r-base">=4.2" conda-forge::r-adegenet conda-forge::r-vcfr conda-forge::r-patchwork conda-forge::r-ggrepel conda-forge::r-ggplot2 conda-forge::r-dplyr conda-forge::r-readr conda-forge::r-tidyr conda-forge::r-tibble conda-forge::r-stringr conda-forge::r-forcats conda-forge::r-scales conda-forge::r-mass'
  }

  withName: REPORT_SNP_CALLING_SUMMARY {
    cpus = 5
    time = '96h'
    memory = { 4.GB * task.attempt }
  }

  // --- samtools_stats ---
  // Trace data: 9.4 - 37 MB peak RSS (streaming, very lightweight)
  withLabel: samtools_stats {
    conda = 'bioconda::samtools'
    cpus = 5
    time = '96h'
    memory = '2 GB'
  }

  // --- multiqc ---
  // Trace data: 1.5 - 2.1 GB peak RSS
  withLabel: multiqc {
    conda = 'bioconda::multiqc'
    cpus = 5
    time = '96h'
    memory = '4 GB'
  }
}

conda {
  enabled = true
  cacheDir = '/work/birdlab/.conda_builds'
  autoActivate = true
  channels = ['bioconda', 'conda-forge', 'defaults']
}

// Execution profiles
profiles {
  slurm {
    process.executor = 'slurm'
  }
  
  local {
    process.executor = 'local'
    process.cpus = 4
    //process.memory = '8 GB'
  }
  
  docker {
    docker.enabled = true
    process.container = 'quay.io/biocontainers/nextflow:latest'
  }
}

// Enable timeline and resource reports
timeline {
  enabled = true
  overwrite = true
  file = "${params.output_dir}/pipeline/snp_pipeline_timeline.html"
}

report {
  enabled = true
  overwrite = true
  file = "${params.output_dir}/pipeline/snp_pipeline_report.html"
}

trace {
  enabled = true
  overwrite = true
  file = "${params.output_dir}/pipeline/snp_pipeline_trace.txt"
}

// Enhanced DAG configuration in nextflow.config
dag {
  enabled = true
  overwrite = true
  file = "${params.output_dir}/pipeline/snp_pipeline_dag.png"
  
  // Additional styling options
  graph {
    // Graph-level attributes
    rankdir = 'TB'          // Top to bottom layout (TB, BT, LR, RL)
    bgcolor = 'white'       // Background color
    fontname = 'Arial'      // Font for the graph
    fontsize = 14           // Font size
    dpi = 300              // Resolution for PNG output
  }
  
  node {
    // Node-level attributes
    shape = 'box'           // Node shape (box, ellipse, circle, etc.)
    style = 'rounded,filled' // Node style
    fillcolor = 'lightblue' // Default fill color
    fontname = 'Arial'      // Font for nodes
    fontsize = 12           // Font size for nodes
  }
  
  edge {
    // Edge-level attributes
    color = 'gray'          // Edge color
    fontname = 'Arial'      // Font for edge labels
    fontsize = 10           // Font size for edge labels
  }
}